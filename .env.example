APP_NAME=Minizon
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://minizon-api.onrender.com

LOG_CHANNEL=stderr
LOG_LEVEL=error

DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=minizon_db
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync
CACHE_STORE=array
FILESYSTEM_DISK=local

# -----------------------------------------------------------------------
# FEDAPAY — Passerelle de paiement Mobile Money
# -----------------------------------------------------------------------
FEDAPAY_SECRET_KEY=sk_sandbox_xxxxxxxxxxxxxx
FEDAPAY_PUBLIC_KEY=pk_sandbox_xxxxxxxxxxxxxx
FEDAPAY_ENVIRONMENT=sandbox
FEDAPAY_WEBHOOK_SECRET=wh_sandbox_xxxxxxxxxxxxxx
FEDAPAY_CALLBACK_URL=https://minizon-api.onrender.com/api/payments/callback
FEDAPAY_COMMISSION_RATE=10

# -----------------------------------------------------------------------
# FCM — Firebase Cloud Messaging (push notifications)
# -----------------------------------------------------------------------
FCM_SERVER_KEY=
